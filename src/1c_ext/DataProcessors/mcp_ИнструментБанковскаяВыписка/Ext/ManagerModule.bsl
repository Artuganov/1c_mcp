// Обработка: mcp_ИнструментБанковскаяВыписка
// Назначение: MCP-инструменты для анализа банковской выписки (безналичные ДС)
// Подключение: подсистема mcp_КонтейнерыИнструментов
//
// Инструменты:
//   get_bank_balances         — текущие остатки на расчётных счетах
//   get_bank_statement        — движения ДС за период (поступления/списания)
//   get_bank_payments_by_partner — оплаты по контрагентам за период

Процедура ДобавитьИнструменты(Инструменты) Экспорт

	ДобавитьИнструментОстаткиНаСчетах(Инструменты);
	ДобавитьИнструментДвиженияДС(Инструменты);
	ДобавитьИнструментОплатыПоКонтрагентам(Инструменты);

КонецПроцедуры

Функция ВыполнитьИнструмент(ИмяИнструмента, Аргументы) Экспорт

	Если ИмяИнструмента = "get_bank_balances" Тогда
		Возврат ОстаткиНаСчетах(Аргументы);
	ИначеЕсли ИмяИнструмента = "get_bank_statement" Тогда
		Возврат ДвиженияДенежныхСредств(Аргументы);
	ИначеЕсли ИмяИнструмента = "get_bank_payments_by_partner" Тогда
		Возврат ОплатыПоКонтрагентам(Аргументы);
	Иначе
		ВызватьИсключение "Неизвестный инструмент: " + ИмяИнструмента;
	КонецЕсли;

КонецФункции

#Область ОстаткиНаСчетах

Процедура ДобавитьИнструментОстаткиНаСчетах(Инструменты)

	МассивПараметров = Новый Массив;

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"bankAccountFilter",
		"string",
		"Фильтр по наименованию банковского счёта (подстрока). Если не указан — все счета."));

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"maxItems",
		"number",
		"Максимальное количество строк в результате",
		50));

	СхемаПараметров = mcp_Метаданные.СхемаПараметровИнструмента(МассивПараметров);

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"get_bank_balances",
		"Получить текущие остатки безналичных денежных средств на банковских счетах организации. Показывает сумму на каждом расчётном счёте. Полезно для быстрого обзора: сколько денег на счетах.",
		СхемаПараметров);

КонецПроцедуры

Функция ОстаткиНаСчетах(Аргументы)

	ФильтрСчёт = ?(Аргументы.Свойство("bankAccountFilter"), Аргументы.bankAccountFilter, "");
	Лимит = ?(Аргументы.Свойство("maxItems"), Аргументы.maxItems, 50);

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Остатки.БанковскийСчет.Наименование КАК БанковскийСчет,
	|	Остатки.Организация.Наименование КАК Организация,
	|	СУММА(Остатки.СуммаОстаток) КАК Остаток,
	|	СУММА(Остатки.КЗачислениюОстаток) КАК КЗачислению,
	|	СУММА(Остатки.КСписаниюОстаток) КАК КСписанию
	|ИЗ
	|	РегистрНакопления.ДенежныеСредстваБезналичные.Остатки КАК Остатки
	|СГРУППИРОВАТЬ ПО
	|	Остатки.БанковскийСчет.Наименование,
	|	Остатки.Организация.Наименование
	|ИМЕЮЩИЕ
	|	СУММА(Остатки.СуммаОстаток) <> 0
	|	ИЛИ СУММА(Остатки.КЗачислениюОстаток) <> 0
	|	ИЛИ СУММА(Остатки.КСписаниюОстаток) <> 0
	|УПОРЯДОЧИТЬ ПО
	|	Остаток УБЫВ";

	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();

	МассивСтрок = Новый Массив;
	МассивСтрок.Добавить("Организация | Банковский счёт | Остаток | К зачислению | К списанию");
	МассивСтрок.Добавить("--- | --- | --- | --- | ---");

	Счетчик = 0;
	ИтогоОстаток = 0;

	Пока Выборка.Следующий() Цикл

		// Фильтр по банковскому счёту
		Если ЗначениеЗаполнено(ФильтрСчёт) Тогда
			Если СтрНайти(ВРег(Выборка.БанковскийСчет), ВРег(ФильтрСчёт)) = 0 Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;

		Строка = "" + Выборка.Организация
			+ " | " + Выборка.БанковскийСчет
			+ " | " + Формат(Выборка.Остаток, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0")
			+ " | " + Формат(Выборка.КЗачислению, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0")
			+ " | " + Формат(Выборка.КСписанию, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0");

		МассивСтрок.Добавить(Строка);

		ИтогоОстаток = ИтогоОстаток + Выборка.Остаток;
		Счетчик = Счетчик + 1;
		Если Счетчик >= Лимит Тогда
			МассивСтрок.Добавить("... (показано " + Лимит + " из больше записей)");
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если Счетчик = 0 Тогда
		Возврат "Остатки на расчётных счетах не найдены.";
	КонецЕсли;

	МассивСтрок.Добавить("");
	МассивСтрок.Добавить("ИТОГО остаток: " + Формат(ИтогоОстаток, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0"));

	Возврат СтрСоединить(МассивСтрок, Символы.ПС);

КонецФункции

#КонецОбласти

#Область ДвиженияДС

Процедура ДобавитьИнструментДвиженияДС(Инструменты)

	МассивПараметров = Новый Массив;

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"startDate",
		"string",
		"Дата начала периода в формате ГГГГММДД (например 20260101). По умолчанию — начало текущего месяца."));

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"endDate",
		"string",
		"Дата конца периода в формате ГГГГММДД (например 20260131). По умолчанию — текущая дата."));

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"groupBy",
		"string",
		"Группировка результатов: 'operation' — по хоз.операциям (по умолчанию), 'article' — по статьям ДДС, 'day' — по дням.",
		"operation",
		,
		"operation,article,day"));

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"maxItems",
		"number",
		"Максимальное количество строк в результате",
		100));

	СхемаПараметров = mcp_Метаданные.СхемаПараметровИнструмента(МассивПараметров);

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"get_bank_statement",
		"Получить сводку движений безналичных денежных средств за период (банковская выписка). Показывает поступления и списания. Можно группировать по хозяйственным операциям, статьям ДДС или по дням. Полезно для анализа: куда уходили деньги, откуда приходили, cash flow за период.",
		СхемаПараметров);

КонецПроцедуры

Функция ДвиженияДенежныхСредств(Аргументы)

	ТекДата = НачалоДня(ТекущаяДатаСеанса());
	НачалоМесяца = НачалоМесяца(ТекДата);

	ДатаНач = НачалоМесяца;
	ДатаКон = ТекДата;

	Если Аргументы.Свойство("startDate") И ЗначениеЗаполнено(Аргументы.startDate) Тогда
		Попытка
			ДатаНач = Дата(Аргументы.startDate + "000000");
		Исключение
			ВызватьИсключение "Неверный формат startDate. Используйте ГГГГММДД, например 20260101";
		КонецПопытки;
	КонецЕсли;

	Если Аргументы.Свойство("endDate") И ЗначениеЗаполнено(Аргументы.endDate) Тогда
		Попытка
			ДатаКон = КонецДня(Дата(Аргументы.endDate + "000000"));
		Исключение
			ВызватьИсключение "Неверный формат endDate. Используйте ГГГГММДД, например 20260131";
		КонецПопытки;
	Иначе
		ДатаКон = КонецДня(ТекДата);
	КонецЕсли;

	Группировка = ?(Аргументы.Свойство("groupBy"), Аргументы.groupBy, "operation");
	Лимит = ?(Аргументы.Свойство("maxItems"), Аргументы.maxItems, 100);

	Если Группировка = "article" Тогда
		ПолеГруппировки = "Обороты.СтатьяДвиженияДенежныхСредств.Наименование";
		ЗаголовокПоля = "Статья ДДС";
	ИначеЕсли Группировка = "day" Тогда
		ПолеГруппировки = "НАЧАЛОПЕРИОДА(Обороты.Период, ДЕНЬ)";
		ЗаголовокПоля = "Дата";
	Иначе
		ПолеГруппировки = "Обороты.ХозяйственнаяОперация";
		ЗаголовокПоля = "Операция";
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	" + ПолеГруппировки + " КАК Группа,
	|	СУММА(Обороты.СуммаПриход) КАК Поступления,
	|	СУММА(Обороты.СуммаРасход) КАК Списания
	|ИЗ
	|	РегистрНакопления.ДенежныеСредстваБезналичные.Обороты(&ДатаНач, &ДатаКон, Авто) КАК Обороты
	|СГРУППИРОВАТЬ ПО
	|	" + ПолеГруппировки + "
	|ИМЕЮЩИЕ
	|	СУММА(Обороты.СуммаПриход) <> 0
	|	ИЛИ СУММА(Обороты.СуммаРасход) <> 0
	|УПОРЯДОЧИТЬ ПО
	|	Списания УБЫВ";

	Запрос.УстановитьПараметр("ДатаНач", ДатаНач);
	Запрос.УстановитьПараметр("ДатаКон", ДатаКон);

	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();

	МассивСтрок = Новый Массив;
	МассивСтрок.Добавить("Движения ДС за период: " + Формат(ДатаНач, "ДФ=dd.MM.yyyy") + " — " + Формат(ДатаКон, "ДФ=dd.MM.yyyy"));
	МассивСтрок.Добавить("");
	МассивСтрок.Добавить(ЗаголовокПоля + " | Поступления | Списания | Нетто");
	МассивСтрок.Добавить("--- | --- | --- | ---");

	Счетчик = 0;
	ВсегоПоступления = 0;
	ВсегоСписания = 0;

	Пока Выборка.Следующий() Цикл

		ЗначениеГруппы = "";
		Если Группировка = "day" Тогда
			ЗначениеГруппы = Формат(Выборка.Группа, "ДФ=dd.MM.yyyy");
		Иначе
			ЗначениеГруппы = "" + Выборка.Группа;
		КонецЕсли;

		Нетто = Выборка.Поступления - Выборка.Списания;

		Строка = ЗначениеГруппы
			+ " | " + Формат(Выборка.Поступления, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0")
			+ " | " + Формат(Выборка.Списания, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0")
			+ " | " + Формат(Нетто, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0");

		МассивСтрок.Добавить(Строка);

		ВсегоПоступления = ВсегоПоступления + Выборка.Поступления;
		ВсегоСписания = ВсегоСписания + Выборка.Списания;

		Счетчик = Счетчик + 1;
		Если Счетчик >= Лимит Тогда
			МассивСтрок.Добавить("... (показано " + Лимит + " строк)");
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если Счетчик = 0 Тогда
		Возврат "Движения ДС не найдены за период " + Формат(ДатаНач, "ДФ=dd.MM.yyyy") + " — " + Формат(ДатаКон, "ДФ=dd.MM.yyyy") + ".";
	КонецЕсли;

	ВсегоНетто = ВсегоПоступления - ВсегоСписания;
	МассивСтрок.Добавить("");
	МассивСтрок.Добавить("ИТОГО | "
		+ Формат(ВсегоПоступления, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0") + " | "
		+ Формат(ВсегоСписания, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0") + " | "
		+ Формат(ВсегоНетто, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0"));

	Возврат СтрСоединить(МассивСтрок, Символы.ПС);

КонецФункции

