		СхемаПараметров);

КонецПроцедуры

Функция ОплатыПоКонтрагентам(Аргументы)

	ТекДата = НачалоДня(ТекущаяДатаСеанса());

	ДатаНач = НачалоМесяца(ТекДата);
	ДатаКон = КонецДня(ТекДата);

	Если Аргументы.Свойство("startDate") И ЗначениеЗаполнено(Аргументы.startDate) Тогда
		Попытка
			ДатаНач = Дата(Аргументы.startDate + "000000");
		Исключение
			ВызватьИсключение "Неверный формат startDate. Используйте ГГГГММДД";
		КонецПопытки;
	КонецЕсли;

	Если Аргументы.Свойство("endDate") И ЗначениеЗаполнено(Аргументы.endDate) Тогда
		Попытка
			ДатаКон = КонецДня(Дата(Аргументы.endDate + "000000"));
		Исключение
			ВызватьИсключение "Неверный формат endDate. Используйте ГГГГММДД";
		КонецПопытки;
	КонецЕсли;

	ФильтрПартнер = ?(Аргументы.Свойство("partnerName"), Аргументы.partnerName, "");
	Направление = ?(Аргументы.Свойство("direction"), Аргументы.direction, "all");
	Лимит = ?(Аргументы.Свойство("maxItems"), Аргументы.maxItems, 50);

	// Используем регистр ДвиженияДенежныеСредстваКонтрагент
	// Фильтруем по типу ДС = Безналичные
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Обороты.Партнер.Наименование КАК Партнер,
	|	Обороты.Контрагент.Наименование КАК Контрагент,
	|	Обороты.ХозяйственнаяОперация КАК Операция,
	|	СУММА(Обороты.СуммаОплатыОборот) КАК СуммаОплаты,
	|	СУММА(Обороты.СуммаПостоплатыОборот) КАК СуммаПостоплаты,
	|	СУММА(Обороты.СуммаПредоплатыОборот) КАК СуммаПредоплаты
	|ИЗ
	|	РегистрНакопления.ДвиженияДенежныеСредстваКонтрагент.Обороты(
	|		&ДатаНач,
	|		&ДатаКон,
	|		Авто,
	|		ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Безналичные)) КАК Обороты
	|СГРУППИРОВАТЬ ПО
	|	Обороты.Партнер.Наименование,
	|	Обороты.Контрагент.Наименование,
	|	Обороты.ХозяйственнаяОперация
	|ИМЕЮЩИЕ
	|	СУММА(Обороты.СуммаОплатыОборот) <> 0
	|УПОРЯДОЧИТЬ ПО
	|	СуммаОплаты УБЫВ";

	Запрос.УстановитьПараметр("ДатаНач", ДатаНач);
	Запрос.УстановитьПараметр("ДатаКон", ДатаКон);

	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();

	МассивСтрок = Новый Массив;
	МассивСтрок.Добавить("Оплаты по контрагентам за период: " + Формат(ДатаНач, "ДФ=dd.MM.yyyy") + " — " + Формат(ДатаКон, "ДФ=dd.MM.yyyy"));
	МассивСтрок.Добавить("");
	МассивСтрок.Добавить("Партнер | Контрагент | Операция | Сумма оплаты | Постоплата | Предоплата");
	МассивСтрок.Добавить("--- | --- | --- | --- | --- | ---");

	Счетчик = 0;
	ИтогоОплата = 0;

	ОперацииПоступления = Новый Массив;
	ОперацииПоступления.Добавить("ОплатаОтКлиента");
	ОперацииПоступления.Добавить("ОплатаОтКлиентаКартой");
	ОперацииПоступления.Добавить("ВозвратОтПоставщика");

	Пока Выборка.Следующий() Цикл

		// Фильтр по направлению
		Если Направление = "incoming" Тогда
			ОперацияСтр = "" + Выборка.Операция;
			ЭтоПоступление = Ложь;
			Для Каждого ОпПост Из ОперацииПоступления Цикл
				Если СтрНайти(ОперацияСтр, ОпПост) > 0 Тогда
					ЭтоПоступление = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			Если НЕ ЭтоПоступление Тогда
				Продолжить;
			КонецЕсли;
		ИначеЕсли Направление = "outgoing" Тогда
			ОперацияСтр = "" + Выборка.Операция;
			ЭтоПоступление = Ложь;
			Для Каждого ОпПост Из ОперацииПоступления Цикл
				Если СтрНайти(ОперацияСтр, ОпПост) > 0 Тогда
					ЭтоПоступление = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			Если ЭтоПоступление Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;

		// Фильтр по имени партнёра
		Если ЗначениеЗаполнено(ФильтрПартнер) Тогда
			ФильтрВРег = ВРег(ФильтрПартнер);
			Если СтрНайти(ВРег(Выборка.Партнер), ФильтрВРег) = 0
				И СтрНайти(ВРег(Выборка.Контрагент), ФильтрВРег) = 0 Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;

		Строка = "" + Выборка.Партнер
			+ " | " + Выборка.Контрагент
			+ " | " + Выборка.Операция
			+ " | " + Формат(Выборка.СуммаОплаты, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0")
			+ " | " + Формат(Выборка.СуммаПостоплаты, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0")
			+ " | " + Формат(Выборка.СуммаПредоплаты, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0");

		МассивСтрок.Добавить(Строка);

		ИтогоОплата = ИтогоОплата + Выборка.СуммаОплаты;
		Счетчик = Счетчик + 1;
		Если Счетчик >= Лимит Тогда
			МассивСтрок.Добавить("... (показано " + Лимит + " строк)");
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если Счетчик = 0 Тогда
		Возврат "Оплаты по контрагентам не найдены за указанный период.";
	КонецЕсли;

	МассивСтрок.Добавить("");
	МассивСтрок.Добавить("ИТОГО оплат: " + Формат(ИтогоОплата, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0") + " (строк: " + Счетчик + ")");

	Возврат СтрСоединить(МассивСтрок, Символы.ПС);

КонецФункции

#КонецОбласти
