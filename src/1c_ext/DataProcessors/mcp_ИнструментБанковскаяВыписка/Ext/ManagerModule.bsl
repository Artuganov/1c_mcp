	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"endDate",
		"string",
		"Дата конца периода в формате ГГГГММДД. По умолчанию — текущая дата."));

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
