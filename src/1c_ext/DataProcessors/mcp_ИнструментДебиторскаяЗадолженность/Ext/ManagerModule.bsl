// Обработка: mcp_ИнструментДебиторскаяЗадолженность
// Назначение: MCP-инструменты для анализа дебиторской задолженности клиентов
// Подключение: подсистема mcp_КонтейнерыИнструментов
//
// Инструменты:
//   get_accounts_receivable — остатки дебиторской задолженности по клиентам
//   get_overdue_debts       — просроченная задолженность по клиентам
//   get_client_debt_details — детализация задолженности конкретного клиента

Процедура ДобавитьИнструменты(Инструменты) Экспорт

	ДобавитьИнструментОстаткиДебиторки(Инструменты);
	ДобавитьИнструментПросроченнаяЗадолженность(Инструменты);
	ДобавитьИнструментДетализацияКлиента(Инструменты);

КонецПроцедуры

Функция ВыполнитьИнструмент(ИмяИнструмента, Аргументы) Экспорт

	Если ИмяИнструмента = "get_accounts_receivable" Тогда
		Возврат ОстаткиДебиторскойЗадолженности(Аргументы);
	ИначеЕсли ИмяИнструмента = "get_overdue_debts" Тогда
		Возврат ПросроченнаяЗадолженность(Аргументы);
	ИначеЕсли ИмяИнструмента = "get_client_debt_details" Тогда
		Возврат ДетализацияЗадолженностиКлиента(Аргументы);
	Иначе
		ВызватьИсключение "Неизвестный инструмент: " + ИмяИнструмента;
	КонецЕсли;

КонецФункции

#Область ОстаткиДебиторскойЗадолженности

Процедура ДобавитьИнструментОстаткиДебиторки(Инструменты)

	МассивПараметров = Новый Массив;

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"minAmount",
		"number",
		"Минимальная сумма задолженности для фильтрации (по умолчанию 0)",
		0));

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"partnerName",
		"string",
		"Фильтр по имени партнёра/контрагента (поиск подстроки, без учёта регистра). Если не указан — все клиенты."));

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"maxItems",
		"number",
		"Максимальное количество строк в результате",
		50));

	СхемаПараметров = mcp_Метаданные.СхемаПараметровИнструмента(МассивПараметров);

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"get_accounts_receivable",
		"Получить текущую дебиторскую задолженность клиентов. Показывает долг и предоплату по каждому партнёру/контрагенту/договору. Можно фильтровать по имени клиента и минимальной сумме.",
		СхемаПараметров);

КонецПроцедуры

Функция ОстаткиДебиторскойЗадолженности(Аргументы)

	МинСумма = ?(Аргументы.Свойство("minAmount"), Аргументы.minAmount, 0);
	ФильтрПартнер = ?(Аргументы.Свойство("partnerName"), Аргументы.partnerName, "");
	Лимит = ?(Аргументы.Свойство("maxItems"), Аргументы.maxItems, 50);

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Остатки.АналитикаУчетаПоПартнерам.Партнер.Наименование КАК Партнер,
	|	Остатки.АналитикаУчетаПоПартнерам.Контрагент.Наименование КАК Контрагент,
	|	Остатки.АналитикаУчетаПоПартнерам.Договор.Наименование КАК Договор,
	|	Остатки.АналитикаУчетаПоПартнерам.Организация.Наименование КАК Организация,
	|	Остатки.Валюта.Наименование КАК Валюта,
	|	СУММА(Остатки.ДолгОстаток) КАК Долг,
	|	СУММА(Остатки.ПредоплатаОстаток) КАК Предоплата
	|ИЗ
	|	РегистрНакопления.РасчетыСКлиентамиПоДокументам.Остатки КАК Остатки
	|СГРУППИРОВАТЬ ПО
	|	Остатки.АналитикаУчетаПоПартнерам.Партнер.Наименование,
	|	Остатки.АналитикаУчетаПоПартнерам.Контрагент.Наименование,
	|	Остатки.АналитикаУчетаПоПартнерам.Договор.Наименование,
	|	Остатки.АналитикаУчетаПоПартнерам.Организация.Наименование,
	|	Остатки.Валюта.Наименование
	|ИМЕЮЩИЕ
	|	СУММА(Остатки.ДолгОстаток) <> 0
	|	ИЛИ СУММА(Остатки.ПредоплатаОстаток) <> 0
	|УПОРЯДОЧИТЬ ПО
	|	Долг УБЫВ";

	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();

	МассивСтрок = Новый Массив;
	МассивСтрок.Добавить("Партнер | Контрагент | Договор | Организация | Валюта | Долг | Предоплата");
	МассивСтрок.Добавить("--- | --- | --- | --- | --- | --- | ---");

	Счетчик = 0;
	Пока Выборка.Следующий() Цикл

		// Фильтр по минимальной сумме
		Если Выборка.Долг < МинСумма И Выборка.Предоплата < МинСумма Тогда
			Продолжить;
		КонецЕсли;

		// Фильтр по имени партнёра
		Если ЗначениеЗаполнено(ФильтрПартнер) Тогда
			ФильтрВРег = ВРег(ФильтрПартнер);
			Если СтрНайти(ВРег(Выборка.Партнер), ФильтрВРег) = 0
				И СтрНайти(ВРег(Выборка.Контрагент), ФильтрВРег) = 0 Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;

		Строка = "" + Выборка.Партнер
			+ " | " + Выборка.Контрагент
			+ " | " + Выборка.Договор
			+ " | " + Выборка.Организация
			+ " | " + Выборка.Валюта
			+ " | " + Формат(Выборка.Долг, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0")
			+ " | " + Формат(Выборка.Предоплата, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0");

		МассивСтрок.Добавить(Строка);

		Счетчик = Счетчик + 1;
		Если Счетчик >= Лимит Тогда
			МассивСтрок.Добавить("... (показано " + Лимит + " из больше записей, увеличьте maxItems)");
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если Счетчик = 0 Тогда
		Возврат "Дебиторская задолженность не найдена по заданным критериям.";
	КонецЕсли;

	Возврат СтрСоединить(МассивСтрок, Символы.ПС);

КонецФункции

#КонецОбласти

#Область ПросроченнаяЗадолженность

Процедура ДобавитьИнструментПросроченнаяЗадолженность(Инструменты)

	МассивПараметров = Новый Массив;

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"daysOverdue",
		"number",
		"Минимальное количество дней просрочки (по умолчанию 1 — любая просрочка)",
		1));

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"minAmount",
		"number",
		"Минимальная сумма просроченного долга",
		0));

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"maxItems",
		"number",
		"Максимальное количество строк в результате",
		50));

	СхемаПараметров = mcp_Метаданные.СхемаПараметровИнструмента(МассивПараметров);

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"get_overdue_debts",
		"Получить просроченную дебиторскую задолженность клиентов. Показывает долги, у которых дата планового погашения уже прошла. Можно фильтровать по количеству дней просрочки и минимальной сумме.",
		СхемаПараметров);

КонецПроцедуры

Функция ПросроченнаяЗадолженность(Аргументы)

	ДнейПросрочки = ?(Аргументы.Свойство("daysOverdue"), Аргументы.daysOverdue, 1);
	МинСумма = ?(Аргументы.Свойство("minAmount"), Аргументы.minAmount, 0);
	Лимит = ?(Аргументы.Свойство("maxItems"), Аргументы.maxItems, 50);

	ДатаГраница = НачалоДня(ТекущаяДатаСеанса()) - ДнейПросрочки * 86400;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Остатки.АналитикаУчетаПоПартнерам.Партнер.Наименование КАК Партнер,
	|	Остатки.АналитикаУчетаПоПартнерам.Контрагент.Наименование КАК Контрагент,
	|	Остатки.АналитикаУчетаПоПартнерам.Договор.Наименование КАК Договор,
	|	Остатки.Валюта.Наименование КАК Валюта,
	|	Остатки.ДатаПлановогоПогашения КАК ДатаПогашения,
	|	РАЗНОСТЬДАТ(Остатки.ДатаПлановогоПогашения, &ТекущаяДата, ДЕНЬ) КАК ДнейПросрочки,
	|	СУММА(Остатки.ДолгОстаток) КАК Долг
	|ИЗ
	|	РегистрНакопления.РасчетыСКлиентамиПоСрокам.Остатки КАК Остатки
	|ГДЕ
	|	Остатки.ДатаПлановогоПогашения <= &ДатаГраница
	|	И Остатки.ДолгОстаток > 0
	|СГРУППИРОВАТЬ ПО
	|	Остатки.АналитикаУчетаПоПартнерам.Партнер.Наименование,
	|	Остатки.АналитикаУчетаПоПартнерам.Контрагент.Наименование,
	|	Остатки.АналитикаУчетаПоПартнерам.Договор.Наименование,
	|	Остатки.Валюта.Наименование,
	|	Остатки.ДатаПлановогоПогашения
	|ИМЕЮЩИЕ
	|	СУММА(Остатки.ДолгОстаток) >= &МинСумма
	|УПОРЯДОЧИТЬ ПО
	|	ДнейПросрочки УБЫВ";

	Запрос.УстановитьПараметр("ДатаГраница", ДатаГраница);
	Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("МинСумма", МинСумма);

	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();

	МассивСтрок = Новый Массив;
	МассивСтрок.Добавить("Партнер | Контрагент | Договор | Валюта | Дата погашения | Дней просрочки | Долг");
	МассивСтрок.Добавить("--- | --- | --- | --- | --- | --- | ---");

	Счетчик = 0;
	Пока Выборка.Следующий() Цикл

		Строка = "" + Выборка.Партнер
			+ " | " + Выборка.Контрагент
			+ " | " + Выборка.Договор
			+ " | " + Выборка.Валюта
			+ " | " + Формат(Выборка.ДатаПогашения, "ДФ=dd.MM.yyyy")
			+ " | " + Выборка.ДнейПросрочки
			+ " | " + Формат(Выборка.Долг, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0");

		МассивСтрок.Добавить(Строка);

		Счетчик = Счетчик + 1;
		Если Счетчик >= Лимит Тогда
			МассивСтрок.Добавить("... (показано " + Лимит + " из больше записей)");
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если Счетчик = 0 Тогда
		Возврат "Просроченная задолженность не найдена (минимум " + ДнейПросрочки + " дней, сумма от " + МинСумма + ").";
	КонецЕсли;

	Возврат СтрСоединить(МассивСтрок, Символы.ПС);

КонецФункции

#КонецОбласти

#Область ДетализацияКлиента

Процедура ДобавитьИнструментДетализацияКлиента(Инструменты)

	МассивПараметров = Новый Массив;

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"partnerName",
		"string",
		"Имя партнёра или контрагента (обязательно, поиск по подстроке)",
		,
		Истина));

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"maxItems",
		"number",
		"Максимальное количество документов в результате",
		30));

	СхемаПараметров = mcp_Метаданные.СхемаПараметровИнструмента(МассивПараметров);

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"get_client_debt_details",
		"Получить детализацию задолженности конкретного клиента — с разбивкой по расчётным документам (реализации, оплаты и т.д.). Показывает долг и предоплату по каждому документу.",
		СхемаПараметров);

КонецПроцедуры

Функция ДетализацияЗадолженностиКлиента(Аргументы)

	ФильтрПартнер = Аргументы.partnerName;
	Лимит = ?(Аргументы.Свойство("maxItems"), Аргументы.maxItems, 30);

	Если НЕ ЗначениеЗаполнено(ФильтрПартнер) Тогда
		ВызватьИсключение "Параметр partnerName обязателен";
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Остатки.АналитикаУчетаПоПартнерам.Партнер.Наименование КАК Партнер,
	|	Остатки.АналитикаУчетаПоПартнерам.Контрагент.Наименование КАК Контрагент,
	|	Остатки.АналитикаУчетаПоПартнерам.Договор.Наименование КАК Договор,
	|	Остатки.РасчетныйДокумент.Представление КАК Документ,
	|	Остатки.Валюта.Наименование КАК Валюта,
	|	Остатки.ДолгОстаток КАК Долг,
	|	Остатки.ПредоплатаОстаток КАК Предоплата
	|ИЗ
	|	РегистрНакопления.РасчетыСКлиентамиПоДокументам.Остатки КАК Остатки
	|ГДЕ
	|	(Остатки.АналитикаУчетаПоПартнерам.Партнер.Наименование ПОДОБНО &МаскаПартнера
	|		ИЛИ Остатки.АналитикаУчетаПоПартнерам.Контрагент.Наименование ПОДОБНО &МаскаПартнера)
	|	И (Остатки.ДолгОстаток <> 0 ИЛИ Остатки.ПредоплатаОстаток <> 0)
	|УПОРЯДОЧИТЬ ПО
	|	Долг УБЫВ";

	Запрос.УстановитьПараметр("МаскаПартнера", "%" + ФильтрПартнер + "%");

	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();

	МассивСтрок = Новый Массив;
	МассивСтрок.Добавить("Детализация задолженности по: " + ФильтрПартнер);
	МассивСтрок.Добавить("");
	МассивСтрок.Добавить("Партнер | Контрагент | Договор | Документ | Валюта | Долг | Предоплата");
	МассивСтрок.Добавить("--- | --- | --- | --- | --- | --- | ---");

	Счетчик = 0;
	ИтогоДолг = 0;
	ИтогоПредоплата = 0;

	Пока Выборка.Следующий() Цикл

		Строка = "" + Выборка.Партнер
			+ " | " + Выборка.Контрагент
			+ " | " + Выборка.Договор
			+ " | " + Выборка.Документ
			+ " | " + Выборка.Валюта
			+ " | " + Формат(Выборка.Долг, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0")
			+ " | " + Формат(Выборка.Предоплата, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0");

		МассивСтрок.Добавить(Строка);

		ИтогоДолг = ИтогоДолг + Выборка.Долг;
		ИтогоПредоплата = ИтогоПредоплата + Выборка.Предоплата;

		Счетчик = Счетчик + 1;
		Если Счетчик >= Лимит Тогда
			МассивСтрок.Добавить("... (показано " + Лимит + " из больше записей)");
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если Счетчик = 0 Тогда
		Возврат "Задолженность по '" + ФильтрПартнер + "' не найдена. Проверьте имя клиента.";
	КонецЕсли;

	МассивСтрок.Добавить("");
	МассивСтрок.Добавить("ИТОГО | | | | | "
		+ Формат(ИтогоДолг, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0") + " | "
		+ Формат(ИтогоПредоплата, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0"));

	Возврат СтрСоединить(МассивСтрок, Символы.ПС);

КонецФункции

#КонецОбласти
