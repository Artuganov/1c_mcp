// Обработка: mcp_ИнструментЗапросКДаннымБазы
// Назначение: универсальный доступ ко всем данным 1С через язык запросов
// Подключение: подсистема mcp_КонтейнерыИнструментов
//
// Инструменты:
//   execute_query    — выполняет произвольный запрос на языке 1С (только ВЫБРАТЬ)
//   describe_metadata — возвращает список объектов метаданных и их реквизитов

Процедура ДобавитьИнструменты(Инструменты) Экспорт

	ДобавитьИнструментВыполнитьЗапрос(Инструменты);
	ДобавитьИнструментОписаниеМетаданных(Инструменты);

КонецПроцедуры

Функция ВыполнитьИнструмент(ИмяИнструмента, Аргументы) Экспорт

	Если ИмяИнструмента = "execute_query" Тогда
		Возврат ВыполнитьЗапрос(Аргументы);
	ИначеЕсли ИмяИнструмента = "describe_metadata" Тогда
		Возврат ОписаниеМетаданных(Аргументы);
	Иначе
		ВызватьИсключение "Неизвестный инструмент: " + ИмяИнструмента;
	КонецЕсли;

КонецФункции

#Область ВыполнитьЗапрос

Процедура ДобавитьИнструментВыполнитьЗапрос(Инструменты)

	МассивПараметров = Новый Массив;

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"query",
		"string",
		"Текст запроса на встроенном языке запросов 1С. Разрешены ТОЛЬКО запросы на чтение (ВЫБРАТЬ / SELECT). Запрос пишется на РУССКОМ языке 1С. Примеры источников: Справочник.Номенклатура, Документ.РеализацияТоваровУслуг, РегистрНакопления.Продажи.Обороты, РегистрСведений.ЦеныНоменклатуры.СрезПоследних и т.д. Используйте describe_metadata чтобы узнать доступные объекты и их реквизиты.",
		,
		Истина));

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"maxRows",
		"number",
		"Максимальное количество строк результата (по умолчанию 100, максимум 1000)",
		100));

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"params",
		"string",
		"JSON-объект с параметрами запроса, например {""ДатаНачала"": ""2025-01-01"", ""Организация"": ""ООО Ромашка""}. Даты в формате ГГГГ-ММ-ДД. Строковые параметры подставляются как есть. Числовые — как числа."));

	СхемаПараметров = mcp_Метаданные.СхемаПараметровИнструмента(МассивПараметров);

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"execute_query",
		"Выполняет произвольный запрос к базе данных 1С на встроенном языке запросов. Только чтение (ВЫБРАТЬ). Позволяет получить любые данные: справочники, документы, регистры, остатки, обороты. Перед запросом используйте describe_metadata чтобы узнать имена таблиц и полей. Лимит строк по умолчанию 100.",
		СхемаПараметров);

КонецПроцедуры

Функция ВыполнитьЗапрос(Аргументы)

	ТекстЗапроса = Аргументы.query;
	МаксСтрок = ?(Аргументы.Свойство("maxRows"), Аргументы.maxRows, 100);
	ПараметрыJSON = ?(Аргументы.Свойство("params"), Аргументы.params, "");

	// Ограничение максимума строк
	Если МаксСтрок > 1000 Тогда
		МаксСтрок = 1000;
	КонецЕсли;
	Если МаксСтрок < 1 Тогда
		МаксСтрок = 100;
	КонецЕсли;

	// === ЗАЩИТА: только запросы на чтение ===
	ОчищенныйТекст = ВРег(СокрЛП(ТекстЗапроса));

	// Убираем комментарии в начале
	Пока СтрНачинаетсяС(ОчищенныйТекст, "//") Цикл
		ПозицияПС = СтрНайти(ОчищенныйТекст, Символы.ПС);
		Если ПозицияПС = 0 Тогда
			ВызватьИсключение "Запрос не содержит оператора ВЫБРАТЬ";
		КонецЕсли;
		ОчищенныйТекст = СокрЛП(Сред(ОчищенныйТекст, ПозицияПС + 1));
	КонецЦикла;

	// Проверяем что запрос начинается с ВЫБРАТЬ или SELECT
	Если НЕ СтрНачинаетсяС(ОчищенныйТекст, "ВЫБРАТЬ")
		И НЕ СтрНачинаетсяС(ОчищенныйТекст, "SELECT") Тогда
		ВызватьИсключение "Разрешены только запросы на чтение (ВЫБРАТЬ / SELECT). Запрос должен начинаться с ВЫБРАТЬ.";
	КонецЕсли;

	// Запрещаем опасные конструкции
	ЗапрещённыеСлова = Новый Массив;
	ЗапрещённыеСлова.Добавить("ПОМЕСТИТЬ");
	ЗапрещённыеСлова.Добавить("INTO");
	ЗапрещённыеСлова.Добавить("УДАЛИТЬ");
	ЗапрещённыеСлова.Добавить("DROP");
	ЗапрещённыеСлова.Добавить("ОБНОВИТЬ");
	ЗапрещённыеСлова.Добавить("UPDATE");
	ЗапрещённыеСлова.Добавить("ВСТАВИТЬ");
	ЗапрещённыеСлова.Добавить("INSERT");

	Для Каждого Слово Из ЗапрещённыеСлова Цикл
		Если СтрНайти(ОчищенныйТекст, Слово) > 0 Тогда
			ВызватьИсключение "Запрещённое ключевое слово в запросе: " + Слово + ". Разрешены только запросы на чтение.";
		КонецЕсли;
	КонецЦикла;

	// === Выполняем запрос ===
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;

	// Устанавливаем параметры из JSON
	Если ЗначениеЗаполнено(ПараметрыJSON) Тогда
		Попытка
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(ПараметрыJSON);
			ПараметрыЗапроса = ПрочитатьJSON(ЧтениеJSON);
			ЧтениеJSON.Закрыть();

			Если ТипЗнч(ПараметрыЗапроса) = Тип("Соответствие") Тогда
				Для Каждого КлючЗначение Из ПараметрыЗапроса Цикл
					Значение = ПривестиЗначениеПараметра(КлючЗначение.Значение);
					Запрос.УстановитьПараметр(КлючЗначение.Ключ, Значение);
				КонецЦикла;
			ИначеЕсли ТипЗнч(ПараметрыЗапроса) = Тип("Структура") Тогда
				Для Каждого КлючЗначение Из ПараметрыЗапроса Цикл
					Значение = ПривестиЗначениеПараметра(КлючЗначение.Значение);
					Запрос.УстановитьПараметр(КлючЗначение.Ключ, Значение);
				КонецЦикла;
			КонецЕсли;
		Исключение
			ВызватьИсключение "Ошибка разбора параметров JSON: " + ОписаниеОшибки();
		КонецПопытки;
	КонецЕсли;

	Попытка
		Результат = Запрос.Выполнить();
	Исключение
		Возврат "ОШИБКА ВЫПОЛНЕНИЯ ЗАПРОСА:" + Символы.ПС + ОписаниеОшибки()
			+ Символы.ПС + Символы.ПС + "Текст запроса:" + Символы.ПС + ТекстЗапроса;
	КонецПопытки;

	// === Формируем результат как markdown-таблицу ===
	Колонки = Результат.Колонки;
	КолВоКолонок = Колонки.Количество();

	Если КолВоКолонок = 0 Тогда
		Возврат "Запрос выполнен, но не вернул колонок.";
	КонецЕсли;

	// Заголовок
	МассивЗаголовков = Новый Массив;
	МассивРазделителей = Новый Массив;
	Для Каждого Колонка Из Колонки Цикл
		МассивЗаголовков.Добавить(Колонка.Имя);
		МассивРазделителей.Добавить("---");
	КонецЦикла;

	МассивСтрок = Новый Массив;
	МассивСтрок.Добавить(СтрСоединить(МассивЗаголовков, " | "));
	МассивСтрок.Добавить(СтрСоединить(МассивРазделителей, " | "));

	// Строки данных
	Выборка = Результат.Выбрать();
	Счетчик = 0;
	Пока Выборка.Следующий() Цикл

		МассивЗначений = Новый Массив;
		Для Каждого Колонка Из Колонки Цикл
			ЗначениеПоля = Выборка[Колонка.Имя];
			МассивЗначений.Добавить(ФорматироватьЗначение(ЗначениеПоля));
		КонецЦикла;

		МассивСтрок.Добавить(СтрСоединить(МассивЗначений, " | "));

		Счетчик = Счетчик + 1;
		Если Счетчик >= МаксСтрок Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если Счетчик = 0 Тогда
		Возврат "Запрос выполнен успешно, но не вернул данных (0 строк).";
	КонецЕсли;

	// Итоговая строка
	ВсегоСтрок = Счетчик;
	ПриПревышении = "";
	Если Счетчик >= МаксСтрок Тогда
		ПриПревышении = " (лимит достигнут, увеличьте maxRows для получения больше данных)";
	КонецЕсли;

	МассивСтрок.Добавить("");
	МассивСтрок.Добавить("Всего строк: " + ВсегоСтрок + ПриПревышении);

	Возврат СтрСоединить(МассивСтрок, Символы.ПС);

КонецФункции

// Форматирует значение поля для вывода
Функция ФорматироватьЗначение(Значение)

	Если Значение = Неопределено ИЛИ Значение = NULL Тогда
		Возврат "";
	КонецЕсли;

	ТипЗначения = ТипЗнч(Значение);

	Если ТипЗначения = Тип("Дата") Тогда
		Если Значение = '00010101' Тогда
			Возврат "";
		КонецЕсли;
		Если Час(Значение) = 0 И Минута(Значение) = 0 И Секунда(Значение) = 0 Тогда
			Возврат Формат(Значение, "ДФ=dd.MM.yyyy");
		Иначе
			Возврат Формат(Значение, "ДФ=dd.MM.yyyy HH:mm:ss");
		КонецЕсли;

	ИначеЕсли ТипЗначения = Тип("Число") Тогда
		Если Цел(Значение) = Значение Тогда
			Возврат Формат(Значение, "ЧГ=0");
		Иначе
			Возврат Формат(Значение, "ЧДЦ=2; ЧРГ= ; ЧГ=3,0");
		КонецЕсли;

	ИначеЕсли ТипЗначения = Тип("Булево") Тогда
		Возврат ?(Значение, "Да", "Нет");

	ИначеЕсли ТипЗначения = Тип("Строка") Тогда
		// Заменяем символы, которые ломают markdown-таблицу
		Результат = СтрЗаменить(Значение, "|", "¦");
		Результат = СтрЗаменить(Результат, Символы.ПС, " ");
		Результат = СтрЗаменить(Результат, Символы.ВК, "");
		Возврат Результат;

	Иначе
		// Для ссылочных типов — представление
		Попытка
			Возврат Строка(Значение);
		Исключение
			Возврат ТипЗначения;
		КонецПопытки;
	КонецЕсли;

КонецФункции

// Приводит значение параметра из JSON к типу 1С
Функция ПривестиЗначениеПараметра(Значение)

	Если ТипЗнч(Значение) <> Тип("Строка") Тогда
		Возврат Значение; // Число, Булево — возвращаем как есть
	КонецЕсли;

	СтрЗначение = СокрЛП(Значение);

	// Проверяем формат даты ГГГГ-ММ-ДД
	Если СтрДлина(СтрЗначение) = 10
		И Сред(СтрЗначение, 5, 1) = "-"
		И Сред(СтрЗначение, 8, 1) = "-" Тогда
		Попытка
			Год  = Число(Лев(СтрЗначение, 4));
			Месяц = Число(Сред(СтрЗначение, 6, 2));
			День  = Число(Прав(СтрЗначение, 2));
			Возврат Дата(Год, Месяц, День);
		Исключение
			// Не дата — вернём как строку
		КонецПопытки;
	КонецЕсли;

	// Проверяем формат даты-времени ГГГГ-ММ-ДДTчч:мм:сс
	Если СтрДлина(СтрЗначение) >= 19
		И Сред(СтрЗначение, 5, 1) = "-"
		И Сред(СтрЗначение, 11, 1) = "T" Тогда
		Попытка
			Год    = Число(Лев(СтрЗначение, 4));
			Месяц  = Число(Сред(СтрЗначение, 6, 2));
			День   = Число(Сред(СтрЗначение, 9, 2));
			Час    = Число(Сред(СтрЗначение, 12, 2));
			Минута = Число(Сред(СтрЗначение, 15, 2));
			Секунда = Число(Сред(СтрЗначение, 18, 2));
			Возврат Дата(Год, Месяц, День, Час, Минута, Секунда);
		Исключение
			// Не дата — вернём как строку
		КонецПопытки;
	КонецЕсли;

	Возврат Значение;

КонецФункции

#КонецОбласти

#Область ОписаниеМетаданных

Процедура ДобавитьИнструментОписаниеМетаданных(Инструменты)

	МассивПараметров = Новый Массив;

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"objectType",
		"string",
		"Тип объекта метаданных для исследования. Если не указан — возвращает список всех типов. Используйте русские имена.",
		,
		Ложь,
		"Справочники,Документы,РегистрыСведений,РегистрыНакопления,РегистрыБухгалтерии,ПланыСчетов,ПланыВидовХарактеристик,Перечисления"));

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"objectName",
		"string",
		"Имя конкретного объекта для получения списка реквизитов. Например: 'Номенклатура', 'РеализацияТоваровУслуг'. Если не указан — возвращает список всех объектов данного типа."));

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"filter",
		"string",
		"Фильтр по имени объекта (поиск подстроки, без учёта регистра). Полезно если объектов много."));

	СхемаПараметров = mcp_Метаданные.СхемаПараметровИнструмента(МассивПараметров);

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"describe_metadata",
		"Исследует структуру базы данных 1С: какие справочники, документы, регистры доступны и какие у них реквизиты. Используйте этот инструмент ПЕРЕД execute_query чтобы узнать правильные имена таблиц и полей. Без параметров — показывает типы объектов. С objectType — список объектов этого типа. С objectType + objectName — реквизиты конкретного объекта.",
		СхемаПараметров);

КонецПроцедуры

Функция ОписаниеМетаданных(Аргументы)

	ТипОбъекта = ?(Аргументы.Свойство("objectType"), СокрЛП(Аргументы.objectType), "");
	ИмяОбъекта = ?(Аргументы.Свойство("objectName"), СокрЛП(Аргументы.objectName), "");
	Фильтр = ?(Аргументы.Свойство("filter"), ВРег(СокрЛП(Аргументы.filter)), "");

	// Без параметров — список типов
	Если НЕ ЗначениеЗаполнено(ТипОбъекта) Тогда
		Возврат СписокТиповМетаданных();
	КонецЕсли;

	// Получаем коллекцию метаданных по типу
	КоллекцияМД = ПолучитьКоллекциюМетаданных(ТипОбъекта);
	Если КоллекцияМД = Неопределено Тогда
		Возврат "Неизвестный тип объекта: " + ТипОбъекта
			+ ". Допустимые: Справочники, Документы, РегистрыСведений, РегистрыНакопления, РегистрыБухгалтерии, ПланыСчетов, ПланыВидовХарактеристик, Перечисления";
	КонецЕсли;

	// Если указано имя — детализация по объекту
	Если ЗначениеЗаполнено(ИмяОбъекта) Тогда
		Возврат ОписаниеРеквизитовОбъекта(КоллекцияМД, ТипОбъекта, ИмяОбъекта);
	КонецЕсли;

	// Иначе — список объектов этого типа
	Возврат СписокОбъектовТипа(КоллекцияМД, ТипОбъекта, Фильтр);

КонецФункции

Функция СписокТиповМетаданных()

	МассивСтрок = Новый Массив;
	МассивСтрок.Добавить("Доступные типы объектов метаданных 1С:");
	МассивСтрок.Добавить("");
	МассивСтрок.Добавить("Тип | Описание | В запросах пишется как");
	МассивСтрок.Добавить("--- | --- | ---");
	МассивСтрок.Добавить("Справочники | Справочная информация (товары, клиенты, склады) | Справочник.ИмяОбъекта");
	МассивСтрок.Добавить("Документы | Хозяйственные операции (продажи, закупки, оплаты) | Документ.ИмяОбъекта");
	МассивСтрок.Добавить("РегистрыСведений | Периодическая и непериодическая информация (цены, курсы) | РегистрСведений.ИмяОбъекта");
	МассивСтрок.Добавить("РегистрыНакопления | Накопительные данные (остатки, обороты, продажи) | РегистрНакопления.ИмяОбъекта.Остатки / .Обороты");
	МассивСтрок.Добавить("РегистрыБухгалтерии | Бухгалтерские проводки | РегистрБухгалтерии.ИмяОбъекта");
	МассивСтрок.Добавить("ПланыСчетов | Планы счетов бухгалтерского учёта | ПланСчетов.ИмяОбъекта");
	МассивСтрок.Добавить("ПланыВидовХарактеристик | Виды характеристик (аналитика) | ПланВидовХарактеристик.ИмяОбъекта");
	МассивСтрок.Добавить("Перечисления | Фиксированные наборы значений | Перечисление.ИмяОбъекта");
	МассивСтрок.Добавить("");
	МассивСтрок.Добавить("Укажите objectType чтобы получить список конкретных объектов.");

	Возврат СтрСоединить(МассивСтрок, Символы.ПС);

КонецФункции

Функция ПолучитьКоллекциюМетаданных(ТипОбъекта)

	Если ТипОбъекта = "Справочники" Тогда
		Возврат Метаданные.Справочники;
	ИначеЕсли ТипОбъекта = "Документы" Тогда
		Возврат Метаданные.Документы;
	ИначеЕсли ТипОбъекта = "РегистрыСведений" Тогда
		Возврат Метаданные.РегистрыСведений;
	ИначеЕсли ТипОбъекта = "РегистрыНакопления" Тогда
		Возврат Метаданные.РегистрыНакопления;
	ИначеЕсли ТипОбъекта = "РегистрыБухгалтерии" Тогда
		Возврат Метаданные.РегистрыБухгалтерии;
	ИначеЕсли ТипОбъекта = "ПланыСчетов" Тогда
		Возврат Метаданные.ПланыСчетов;
	ИначеЕсли ТипОбъекта = "ПланыВидовХарактеристик" Тогда
		Возврат Метаданные.ПланыВидовХарактеристик;
	ИначеЕсли ТипОбъекта = "Перечисления" Тогда
		Возврат Метаданные.Перечисления;
	Иначе
		Возврат Неопределено;
	КонецЕсли;

КонецФункции

Функция СписокОбъектовТипа(КоллекцияМД, ТипОбъекта, Фильтр)

	МассивСтрок = Новый Массив;
	МассивСтрок.Добавить("Объекты типа: " + ТипОбъекта);
	МассивСтрок.Добавить("");
	МассивСтрок.Добавить("Имя | Синоним");
	МассивСтрок.Добавить("--- | ---");

	Счетчик = 0;
	Для Каждого МДОбъект Из КоллекцияМД Цикл

		Если ЗначениеЗаполнено(Фильтр) Тогда
			Если СтрНайти(ВРег(МДОбъект.Имя), Фильтр) = 0
				И СтрНайти(ВРег(МДОбъект.Синоним), Фильтр) = 0 Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;

		МассивСтрок.Добавить(МДОбъект.Имя + " | " + МДОбъект.Синоним);
		Счетчик = Счетчик + 1;

		Если Счетчик >= 500 Тогда
			МассивСтрок.Добавить("... (показано 500 объектов, используйте filter для сужения)");
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если Счетчик = 0 Тогда
		Возврат "Не найдено объектов типа " + ТипОбъекта
			+ ?(ЗначениеЗаполнено(Фильтр), " с фильтром '" + Фильтр + "'", "") + ".";
	КонецЕсли;

	МассивСтрок.Добавить("");
	МассивСтрок.Добавить("Всего: " + Счетчик + ". Укажите objectName для получения реквизитов.");

	Возврат СтрСоединить(МассивСтрок, Символы.ПС);

КонецФункции

Функция ОписаниеРеквизитовОбъекта(КоллекцияМД, ТипОбъекта, ИмяОбъекта)

	МДОбъект = КоллекцияМД.Найти(ИмяОбъекта);
	Если МДОбъект = Неопределено Тогда
		Возврат "Объект '" + ИмяОбъекта + "' не найден в " + ТипОбъекта + ". Проверьте имя.";
	КонецЕсли;

	ИмяВЗапросе = ПолучитьПрефиксТипаДляЗапроса(ТипОбъекта);

	МассивСтрок = Новый Массив;
	МассивСтрок.Добавить("Объект: " + ТипОбъекта + "." + ИмяОбъекта + " (" + МДОбъект.Синоним + ")");
	МассивСтрок.Добавить("В запросе: " + ИмяВЗапросе + "." + ИмяОбъекта);
	МассивСтрок.Добавить("");

	// Стандартные реквизиты
	Попытка
		СтандартныеРеквизиты = МДОбъект.СтандартныеРеквизиты;
		Если СтандартныеРеквизиты <> Неопределено Тогда
			МассивСтрок.Добавить("### Стандартные реквизиты");
			МассивСтрок.Добавить("Имя | Синоним | Тип");
			МассивСтрок.Добавить("--- | --- | ---");
			Для Каждого СтдРекв Из СтандартныеРеквизиты Цикл
				МассивСтрок.Добавить(СтдРекв.Имя + " | " + СтдРекв.Синоним + " | " + Строка(СтдРекв.Тип));
			КонецЦикла;
			МассивСтрок.Добавить("");
		КонецЕсли;
	Исключение
		// Нет стандартных реквизитов для этого типа
	КонецПопытки;

	// Реквизиты
	Попытка
		Реквизиты = МДОбъект.Реквизиты;
		Если Реквизиты <> Неопределено И Реквизиты.Количество() > 0 Тогда
			МассивСтрок.Добавить("### Реквизиты");
			МассивСтрок.Добавить("Имя | Синоним | Тип");
			МассивСтрок.Добавить("--- | --- | ---");
			Для Каждого Рекв Из Реквизиты Цикл
				МассивСтрок.Добавить(Рекв.Имя + " | " + Рекв.Синоним + " | " + Строка(Рекв.Тип));
			КонецЦикла;
			МассивСтрок.Добавить("");
		КонецЕсли;
	Исключение
		// Нет реквизитов
	КонецПопытки;

	// Табличные части
	Попытка
		ТабличныеЧасти = МДОбъект.ТабличныеЧасти;
		Если ТабличныеЧасти <> Неопределено И ТабличныеЧасти.Количество() > 0 Тогда
			Для Каждого ТЧ Из ТабличныеЧасти Цикл
				МассивСтрок.Добавить("### Табличная часть: " + ТЧ.Имя + " (" + ТЧ.Синоним + ")");
				МассивСтрок.Добавить("В запросе: " + ИмяВЗапросе + "." + ИмяОбъекта + "." + ТЧ.Имя);
				МассивСтрок.Добавить("Имя | Синоним | Тип");
				МассивСтрок.Добавить("--- | --- | ---");
				Для Каждого Рекв Из ТЧ.Реквизиты Цикл
					МассивСтрок.Добавить(Рекв.Имя + " | " + Рекв.Синоним + " | " + Строка(Рекв.Тип));
				КонецЦикла;
				МассивСтрок.Добавить("");
			КонецЦикла;
		КонецЕсли;
	Исключение
		// Нет табличных частей
	КонецПопытки;

	// Измерения (для регистров)
	Попытка
		Измерения = МДОбъект.Измерения;
		Если Измерения <> Неопределено И Измерения.Количество() > 0 Тогда
			МассивСтрок.Добавить("### Измерения");
			МассивСтрок.Добавить("Имя | Синоним | Тип");
			МассивСтрок.Добавить("--- | --- | ---");
			Для Каждого Изм Из Измерения Цикл
				МассивСтрок.Добавить(Изм.Имя + " | " + Изм.Синоним + " | " + Строка(Изм.Тип));
			КонецЦикла;
			МассивСтрок.Добавить("");
		КонецЕсли;
	Исключение
		// Нет измерений
	КонецПопытки;

	// Ресурсы (для регистров)
	Попытка
		Ресурсы = МДОбъект.Ресурсы;
		Если Ресурсы <> Неопределено И Ресурсы.Количество() > 0 Тогда
			МассивСтрок.Добавить("### Ресурсы");
			МассивСтрок.Добавить("Имя | Синоним | Тип");
			МассивСтрок.Добавить("--- | --- | ---");
			Для Каждого Рес Из Ресурсы Цикл
				МассивСтрок.Добавить(Рес.Имя + " | " + Рес.Синоним + " | " + Строка(Рес.Тип));
			КонецЦикла;
			МассивСтрок.Добавить("");
		КонецЕсли;
	Исключение
		// Нет ресурсов
	КонецПопытки;

	Возврат СтрСоединить(МассивСтрок, Символы.ПС);

КонецФункции

Функция ПолучитьПрефиксТипаДляЗапроса(ТипОбъекта)

	Если ТипОбъекта = "Справочники" Тогда
		Возврат "Справочник";
	ИначеЕсли ТипОбъекта = "Документы" Тогда
		Возврат "Документ";
	ИначеЕсли ТипОбъекта = "РегистрыСведений" Тогда
		Возврат "РегистрСведений";
	ИначеЕсли ТипОбъекта = "РегистрыНакопления" Тогда
		Возврат "РегистрНакопления";
	ИначеЕсли ТипОбъекта = "РегистрыБухгалтерии" Тогда
		Возврат "РегистрБухгалтерии";
	ИначеЕсли ТипОбъекта = "ПланыСчетов" Тогда
		Возврат "ПланСчетов";
	ИначеЕсли ТипОбъекта = "ПланыВидовХарактеристик" Тогда
		Возврат "ПланВидовХарактеристик";
	ИначеЕсли ТипОбъекта = "Перечисления" Тогда
		Возврат "Перечисление";
	Иначе
		Возврат ТипОбъекта;
	КонецЕсли;

КонецФункции

#КонецОбласти
